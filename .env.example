# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=False
DEBUG=False

# Server Configuration
PORT=5000
HOST=0.0.0.0

# Database Configuration (MongoDB)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/krishisetu?retryWrites=true&w=majority

# JWT Secret Keys (Generate secure keys in production)
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# CORS Settings (add your Netlify frontend URL here)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,https://your-netlify-site.netlify.app

# Email Configuration (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_USE_TLS=True

# Application Settings
APP_NAME=KrishiSetu
APP_VERSION=1.0.0
